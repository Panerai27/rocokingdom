---
export interface Props {
  title: string;
  description: string;
  /** 相对站点根（不含 base）的规范路径，如 "/wiki/foo" 或 "/" */
  path: string;
  type?: 'website' | 'article';
  keywords?: string[];
  publishedTime?: string;
  modifiedTime?: string;
  /** 额外注入到 head 的 JSON-LD 对象数组 */
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description,
  path,
  type = 'website',
  keywords = [],
  publishedTime,
  modifiedTime,
  jsonLd = [],
} = Astro.props;

const SITE_NAME = 'Rocokingdom Wiki';
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // e.g. /rocokingdom
const withBase = (p: string) => `${base}${p.startsWith('/') ? p : '/' + p}`;
const canonical = new URL(withBase(path), Astro.site).toString();

const nav = [
  { href: '/wiki', label: '全部词条' },
  { href: '/wiki/beginner-guide', label: '新手指南' },
  { href: '/wiki/pet-tier-list', label: '宠物榜单' },
  { href: '/wiki/event-calendar', label: '活动日历' },
  { href: '/faq', label: '常见问题' },
  { href: '/about', label: '关于' },
];
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | {SITE_NAME}</title>
  <meta name="description" content={description} />
  {keywords.length > 0 && <meta name="keywords" content={keywords.join(',')} />}
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index,follow,max-image-preview:large" />

  <meta property="og:type" content={type} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta name="twitter:card" content="summary_large_image" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

  <link rel="stylesheet" href={withBase('/styles.css')} />

  <!-- Google AdSense: 替换 ca-pub-XXXXXXXXXXXXXXXX 为你的真实 client id -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>

  {jsonLd.map((obj) => (
    <script type="application/ld+json" set:html={JSON.stringify(obj)} />
  ))}
</head>
<body>
  <header>
    <div class="wrap nav">
      <a class="brand" href={withBase('/')}>Rocokingdom Wiki</a>
      <nav class="nav-links" aria-label="主导航">
        {nav.map((item) => (
          <a href={withBase(item.href)}>{item.label}</a>
        ))}
      </nav>
    </div>
  </header>

  <main class="wrap">
    <slot />
  </main>

  <footer>
    <div class="wrap">
      <p>Rocokingdom Wiki 与游戏官方无隶属关系。请遵守相关法律与平台政策使用本站内容。</p>
      <p>
        <a href={withBase('/about')}>关于我们</a> ·
        <a href={withBase('/contact')}>联系我们</a> ·
        <a href={withBase('/privacy')}>隐私政策</a>
      </p>
    </div>
  </footer>
</body>
</html>
